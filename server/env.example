DATABASE_URL="postgresql://user:password@localhost:5432/spin-master?schema=public"

# Jest (unit + functional): use a separate database from dev — never point this at data you care about.
# Create the empty DB once, then: npm run prisma:migrate:test
DATABASE_URL_TEST="postgresql://user:password@localhost:5432/spin_master_test?schema=public"
# Optional: run tests against DATABASE_URL above (not recommended for local dev)
# ALLOW_JEST_ON_DEV_DATABASE="true"

JWT_SECRET="your-secret-key-change-this-in-production"
PORT=3001

# Logging Configuration
# Quick debug mode: set DEBUG=true to enable all logging (file + console + debug level)
DEBUG=true

# Set to 'true' to enable file logging (logs saved to server/logs/server-YYYY-MM-DD.log)
ENABLE_LOGGING=false
# Set to 'true' to also log to console
LOG_TO_CONSOLE=false
# Log level: 'info' or 'debug' (DEBUG=true automatically sets this to 'debug')
# LOG_LEVEL=debug

# Note: Setting DEBUG=true enables:
# - File logging (ENABLE_LOGGING)
# - Console logging (LOG_TO_CONSOLE)
# - Debug log level (LOG_LEVEL=debug)

# Optional: used by `npm run setup-supabase-initial`
SYS_ADMIN_EMAIL="sys-admin@fake.local"
SYS_ADMIN_PASSWORD="Admin123!"
SYS_ADMIN_FIRST_NAME="Sys"
SYS_ADMIN_LAST_NAME="Admin"

# SMTP (required for forgot-password and admin reset-link emails)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user@example.com"
SMTP_PASS="smtp-password"
SMTP_FROM="Spin Master <no-reply@example.com>"
# Optional SMTP TLS controls
# SMTP_REQUIRE_TLS="false"
# SMTP_IGNORE_TLS="false"
# SMTP_TLS_REJECT_UNAUTHORIZED="true"


